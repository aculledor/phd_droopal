{#
/**
 * @file
 * Template for the main page.
 */
#}
{% set page_attributes = attributes ?: create_attribute() %}
{% set
  page_classes = [
    'page',
  ]|merge(page_utility_classes ?: [])
%}

{% set
  main_classes = [
    'main',
  ]|merge(page_main_utility_classes ?: ['py-4', 'py-sm-5'])
%}

<div {{ page_attributes.addClass(page_classes, theme_hook_suggestions|map(c => c|clean_class)) }}>
  <div class="page-wrapper">
    {% block page_header %}
      {% include 'citius:page-header' %}
    {% endblock %}

    <div class="page-content">
      {% block page_aside %}
        {% include 'citius:page-aside' %}
      {% endblock %}

      <div class="content-wrapper">
        {% block page_precontent %}
          {{ page.pre_content }}
        {% endblock %}

        {% block page_content %}
          {{ page.content }}
        {% endblock %}

        {% block page_postcontent %}
          {{ page.post_content }}
        {% endblock %}
      </div>
    </div>
  </div>

	{% block page_prefooter %}
		{% include 'citius:page-prefooter' %}
	{% endblock %}

	{% block page_footer %}
		{% include 'citius:page-footer' %}
	{% endblock %}
</div>
