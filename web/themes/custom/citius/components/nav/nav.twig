{#
/**
 * @file
 * Template for a nav menu component.
 *
 * Available variables:
 * - menu_name: The machine name of the menu.
 * - items: A nested list of menu items. Each menu item contains:
 *   - attributes: HTML attributes for the menu item.
 *   - below: The menu item child items.
 *   - title: The menu link title.
 *   - url: The menu link URL, instance of \Drupal\Core\Url
 *   - localized_options: Menu link localized options.
 *   - is_expanded: TRUE if the link has visible children within the current
 *     menu tree.
 *   - is_collapsed: TRUE if the link has children within the current menu tree
 *     that are not currently visible.
 *   - in_active_trail: TRUE if the link is in the active trail.
 */
 *
#}
{% import _self as menus %}

{% set nav_attributes = attributes ?: create_attribute() %}
{%
  set nav_classes = [
    'menu',
    'menu-' ~ menu_name|clean_class,
    'nav',
  ]
%}
{{ menus.menu_links(items, attributes.addClass(nav_classes), 0) }}

{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes }}>
    {% else %}
      <ul class="nav__submenu">
    {% endif %}
    {% for item in items %}
      {%
        set nav_item_classes = [
          'nav__item',
          item.in_active_trail ? 'is-active' : '',
          item.in_active_trail ? 'open' : '',
          item.is_expanded and item.below ? 'nav__item--has-children' : ''
        ]|merge(nav_item_utility_classes ?: [])
      %}
      {%
        set nav_link_classes = [
          'nav__link',
          item.in_active_trail ? 'is-active' : '',
          item.icon ? 'nav__link-icon',
          item.icon ? 'icon-' ~ item.icon,
        ]|merge(nav_link_utility_classes ?: [])
      %}

      <li{{ item.attributes.addClass(nav_item_classes|merge(['nav__item'])) }}>
        {{ link(item.title, item.url, { 'class': nav_link_classes|merge(['nav__link']), 'aria-expanded': item.in_active_trail ? 'true' : 'false' }) }}
        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1) }}
        {% endif %}
      </li>
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
